# URL of the FastAPI backend running on the mini PC.
# For local development (backend on the same machine):
NEXT_PUBLIC_API_URL=http://localhost:8000

# For accessing the mini PC from another device on the same LAN:
# NEXT_PUBLIC_API_URL=http://192.168.1.50:8000

# For remote access (Vercel deployment), use a public IP or tunnel:
# NEXT_PUBLIC_API_URL=https://your-domain.com
